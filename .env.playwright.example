# If omitted, Playwright follows VITE_PUBLIC_APP_ORIGIN from .env.local.
PW_BASE_HOST=
PW_BASE_PORT=

# Customer multi-context baseline
PW_CUSTOMER_STORE=
PW_CUSTOMER_QR=
PW_CUSTOMER_CONTEXTS=4
PW_CUSTOMER_ORDER_CONTEXTS=4
PW_CUSTOMER_ORDERS_PER_CONTEXT=1
PW_ORDER_STAGGER_MS=750
PW_DISABLE_STAFF_FALLBACK=0
PW_METRICS_OUTPUT_PATH=tests/e2e/artifacts/load-metrics.jsonl
PW_MAX_REQUEST_MS=
PW_MAX_TOTAL_MS=
PW_MAX_STAFF_PROPAGATION_MS=
PW_MAX_KDS_PROPAGATION_MS=

# Optional: enable a real order submit from the first customer context
PW_EXERCISE_ORDER_FLOW=0
PW_CUSTOMER_ORDER_ITEM_NAME=

# Optional: auxiliary backoffice contexts
PW_STAFF_EMAIL=
PW_STAFF_PASSWORD=
PW_KDS_EMAIL=
PW_KDS_PASSWORD=
PW_STAFF_STORAGE_STATE_PATH=tests/e2e/artifacts/auth/staff.json
PW_KDS_STORAGE_STATE_PATH=tests/e2e/artifacts/auth/kds.json
